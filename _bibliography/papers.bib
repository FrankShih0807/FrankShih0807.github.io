  title        = {Fast Value Tracking for Deep Reinforcement Learning},
  author       = {Shih, Frank and Liang, Faming},
  booktitle    = {International Conference on Learning Representations (ICLR)},
  year         = {2024},
  url          = {https://arxiv.org/abs/2403.13178},
  html         = {https://arxiv.org/abs/2403.13178},
  arxiv        = {2403.13178},
  abstract     = {We introduce Langevinized Kalman Temporal-Difference (LKTD), a stochastic-gradient-MCMC algorithm for deep reinforcement learning that tracks the posterior distribution of value-function parameters efficiently. The method provides calibrated uncertainty estimates for Q-values and yields improved sample efficiency across standard control benchmarks.}
